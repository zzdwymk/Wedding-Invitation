/* animate.css */
.animated {
  animation-duration: 1s;
  animation-fill-mode: both;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.fadeIn {
  animation-name: fadeIn;
}

@keyframes slideInUp {
  from {
    transform: translate3d(0, 100%, 0);
    visibility: visible;
  }
  to {
    transform: translate3d(0, 0, 0);
  }
}

.slideInUp {
  animation-name: slideInUp;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: '华文楷体', '华文中宋', Arial, sans-serif;
  background: #ffffff;
}

/* 自定义导航栏 */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  transition: all 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.nav-title {
  color: #333333;
  top: 60rpx;
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  line-height: 100rpx;
  font-weight: bold;
  position: absolute;
  z-index: 1;
  font-family: '华文楷体';
}

.content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 150rpx;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  position: relative;
  z-index: 1;
  background: transparent;
}

/* 页面分段样式 */
.section {
  opacity: 0;
  transform: translateY(50px);
  transition: all 0.6s ease;
  margin: 0;
}

.section.show {
  opacity: 1;
  transform: translateY(0);
  animation: fadeIn 1s ease forwards;
}

