.map-page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.back-btn {
  position: absolute;
  left: 0;
  top: 70rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  color: #333333;
  top: 60rpx;
  width: 100%;
  text-align: center;
  font-size: 35rpx;
  line-height: 100rpx;
  font-weight: bold;
  position: absolute;
  z-index: 1;
  font-family: '华文楷体';
}

.map {
  width: 100%;
  height: 100%;
  /* padding-top: 180rpx; */
  box-sizing: border-box;
}

.location-info {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  z-index: 99;
}

.info-card {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 50rpx;
  padding: 30rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.5);
}

.info-header {
  margin-bottom: 20rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #b71c1c;
  font-family: '华文行楷';
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.info-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-nav, .btn-call {
  flex: 1;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-nav {
  background: linear-gradient(135deg, #b71c1c, #d32f2f);
  color: #fff;
}

.btn-call {
  background: #f5f5f5;
  color: #b71c1c;
  border: 2rpx solid #b71c1c;
}