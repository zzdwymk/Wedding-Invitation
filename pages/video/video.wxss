.video-page {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(1px);
  -webkit-backdrop-filter: blur(1px);
}

.back-btn {
  position: absolute;
  left: 0;
  top: 70rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  color: #333333;
  top: 60rpx;
  width: 100%;
  text-align: center;
  font-size: 35rpx;
  line-height: 120rpx;
  font-weight: bold;
  position: absolute;
  z-index: 1;
  font-family: '华文楷体';
}

.video-list {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
}

.video-item {
  width: 100%;
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
}

.video-player {
  width: 100%;
  height: 400rpx;
}

.video-title {
  display: block;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  font-family: '华文行楷';
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}