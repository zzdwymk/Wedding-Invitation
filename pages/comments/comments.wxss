.comments-page {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  box-sizing: border-box;
}

.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(1px);
  -webkit-backdrop-filter: blur(1px);
}

.back-btn {
  position: absolute;
  left: 0;
  top: 70rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  color: #333333;
  /* top: 60rpx; */
  width: 100%;
  text-align: center;
  font-size: 35rpx;
  line-height: 120rpx;
  font-weight: bold;
  position: absolute;
  z-index: 1;
  font-family: '华文楷体';
}


.comment-item {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
}

.comment-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #b71c1c, #d32f2f);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.comment-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}